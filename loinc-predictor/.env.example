# LOINC Predictor — Environment Configuration
# Copy to backend/.env and fill in your values:
#   cp .env.example backend/.env

# ── Required ──────────────────────────────────────────────────────────────────
# Absolute path to the full LOINC CSV (download from https://loinc.org/downloads/)
LOINC_CSV_PATH=/absolute/path/to/Loinc.csv

# Absolute path to the models directory (relative to where the server is run from)
# FAISS index and embeddings are auto-generated on first boot from the CSV.
# Place your fine-tuned sbert_finetuned/ here for maximum accuracy.
MODELS_DIR=/absolute/path/to/loinc_predictor/loinc_biobert_models

# ── Optional ──────────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8001

# OCR engine: tesseract | easyocr | auto
# Recommendation: use 'tesseract' on macOS (easyocr segfaults with recent PyTorch)
# Install Tesseract: brew install tesseract  (macOS) | apt install tesseract-ocr (Ubuntu)
OCR_ENGINE=tesseract

# Tesseract binary path override (Windows only)
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# CORS — comma-separated origins (use * for local dev, restrict in production)
CORS_ORIGINS=*
